# ============================================================
# SOCIAL MEDIA BRAIN — Environment Variables
# Copy this to .env in your n8n instance and fill in values
# ============================================================

# ── n8n ─────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com
N8N_API_KEY=your_n8n_api_key

# ── Claude / Anthropic ──────────────────────────────────────
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── RapidAPI (TikTok + Instagram data) ──────────────────────
# Subscribe to "TikTok API23" and "Instagram Scraper API2" at rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key

# ── TikTok ──────────────────────────────────────────────────
# Create app at: https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
MY_TIKTOK_USERNAME=your_tiktok_username
# Comma-separated creators to monitor (no @ symbol)
TRACK_CREATORS=charlidamelio,khaby.lame,bellapoarch,yourcompetitor

# ── YouTube ─────────────────────────────────────────────────
# Create project at: https://console.developers.google.com
YOUTUBE_API_KEY=AIzaSy...
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxx
# OAuth token from Google OAuth2 flow (for posting)
YOUTUBE_OAUTH_TOKEN=ya29....

# ── Instagram ───────────────────────────────────────────────
# Create app at: https://developers.facebook.com
# Requires Instagram Business Account connected to Facebook Page
INSTAGRAM_ACCESS_TOKEN=IGQVJx...
INSTAGRAM_BUSINESS_ID=17841400000000000

# ── Twitter / X ─────────────────────────────────────────────
# Create app at: https://developer.twitter.com
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# ── Notion ──────────────────────────────────────────────────
# Create integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
# Database IDs — copy from Notion page URL after the workspace name
NOTION_TRENDS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CREATOR_INTEL_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PERFORMANCE_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PIPELINE_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CALENDAR_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ENGAGEMENT_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_REPORTS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Video Generation ────────────────────────────────────────
# Runway ML: https://app.runwayml.com/account/api-keys
RUNWAYML_API_KEY=key_...

# ── Voice / TTS ─────────────────────────────────────────────
# ElevenLabs: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Find voice IDs at: https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Image Generation (HTML/CSS → Image) ─────────────────────
# HCTI: https://htmlcsstoimage.com/dashboard
HCTI_USER_ID=your_hcti_user_id
HCTI_API_KEY=your_hcti_api_key

# ── Notifications ────────────────────────────────────────────
# Slack incoming webhook: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
ALERT_EMAIL=you@yourdomain.com
